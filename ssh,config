Host *
  compression yes
  # Mitigation for CVE-0216-0778.
  # Server-side roaming was never implemented anyway.
  # See: http://undeadly.org/cgi?action=article&sid=20160114142733
  UseRoaming no
  # macOS Sierra/10.2 or later only:
  # Let ssh-agent remember keys on macOS Sierra 10.12+.
  # See: https://developer.apple.com/library/archive/technotes/tn2449/
  UseKeychain yes
  AddKeysToAgent yes

Host heroku.com
  PreferredAuthentications publickey
  IdentityFile ~/.ssh/id_heroku

Host silver.bnr
  Port 9822
  User jsherman

Host github.com 207.97.227.239 204.232.175.90 192.30.252.0/22
  User git
  PreferredAuthentications publickey
  IdentityFile ~/.ssh/id_github
  # Next 2 lines enable using SSH over HTTPS port.
  # https://help.github.com/en/github/authenticating-to-github/using-ssh-over-the-https-port
  Hostname ssh.github.com
  Port 443

Host gitlab.com
  PreferredAuthentications publickey
  IdentityFile ~/.ssh/id_github

# use id_bitbucket for bnrjeremy
