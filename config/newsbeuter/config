# [Automatic Reloading]
auto-reload yes
refresh-on-startup yes
# suppress reload on launch when auto-reloading
suppress-first-reload yes

#browser - default lynx
browser "open %u"

error-log "~/.config/newsbeuter/error.log"

# If set, then "show-urls" will pipe the current article to a specific external tool instead of using the internal URL viewer. This can be used to integrate tools such as urlview. 
#external-url-viewer 

prepopulate-query-feeds yes
save-path "~/Documents/Newsbeuter Saved Articles"

# separate file lets you :source $FILE at runtime to try new things
include "~/.config/newsbeuter/formats"
include "~/.config/newsbeuter/keys"
# simpler not to use ttrss - didn't like any of the iOS apps, anyway
#include "~/.config/newsbeuter/ttrss"
include "~/.config/newsbeuter/notify"

# [Bookmarking]
#bookmark-cmd - path to command to execute on a bookmarked URL
#bookmark-interactive - set "yes" if it is interactive; default "no"
#bookmark-autopilot - set "yes" to skip confirming title/URL when possible

