{
  // Place your snippets for mercury here. Each snippet is defined under a snippet name and has a prefix, body and
  // description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
  // $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the
  // same ids are connected.
  // Example:
  // "Print to console": {
  // 	"prefix": "log",
  // 	"body": [
  // 		"console.log('$1');",
  // 		"$2"
  // 	],
  // 	"description": "Log output to console"
  // }
  "Module skeleton": {
    "prefix": ":- module",
    "body": [
      ":- module ${1:your_filename}.",
      "",
      ":- interface.",
      ":- import_module ${2:io}.",
      "$0",
      "",
      ":- implementation.",
      "$3"
    ]
  },
  "Import": {
    "prefix": "import",
    "body": ":- import_module $1."
  },
  "Separator": {
    "prefix": "SEP",
    "body": "%-----------------------------------------------------------------------------%"
  },
  "Declare IO pred": {
    "prefix": "diop",
    "body": [":- pred ${1:name}(${2:type1::in,} io::di, io::uo) is ${3:det}."]
  },
  "!IO": {
    "prefix": "bio",
    "body": ["!IO"],
    "description": "Mnemonic: b(ang) io."
  },
  "Trace with IO": {
    "prefix": "traceio",
    "body": ["trace [io(!IO)] (io.write_line({${1:\"eh?\"}}, !IO)),"]
  },
  ":-": {
    "prefix": "cos",
    "body": [":- "],
    "description": "Mnemonic: cos = because."
  },
  "Declare a function": {
    "prefix": "dfunc",
    "body": [
      ":- func ${1:name}(${2:T1}) = ${3:R}.",
      "$1($2) = $3 :-",
      "    ${4:true}."
    ]
  },
  "Declare a predicate": {
    "prefix": "dpred",
    "body": [
      ":- pred ${1:name}(${2:_X::in}) is ${3:det}.",
      "${1:name}($2) :-",
      "    ${4:true}."
    ]
  },
  "Lambda predicate": {
    "prefix": "lpred",
    "body": ["(pred(${1:X::in}, ${2:Y::out}) is ${3:det} :-", "    ${4:true}),"]
  },
  "Lambda function": {
    "prefix": "lfunc",
    "body": ["(func(${1:X}) = ${2:Result} :-", "    Result = ${3:true}),"]
  },
  "If-then-else": {
    "prefix": "if",
    "body": [
      "(if",
      "    ${1:mightFail}",
      " then",
      "    ${2:onSuccess}",
      " else",
      "     ${3:onFailure}",
      ")"
    ]
  }
}
