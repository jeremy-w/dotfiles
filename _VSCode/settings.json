// Place your settings in this file to overwrite the default settings
// See: https://code.visualstudio.com/docs/getstarted/settings
{
    "breadcrumbs.enabled": true,
    "diffEditor.renderSideBySide": false,

    "editor.find.autoFindInSelection": true,
    "editor.fontFamily": "Verdana, 'Go Regular', InputSans, Georgia, proportional",
    "editor.fontSize": 16,
    "editor.renderWhitespace": "boundary",
    "editor.wordWrap": "on",
    "editor.wrappingIndent": "indent",
    "editor.scrollBeyondLastLine": false,
    "editor.renderLineHighlight": "all",
    "editor.renderControlCharacters": true,
    "editor.showFoldingControls": "always",
    "editor.minimap.renderCharacters": false,
    "editor.formatOnSave": false,
    "editor.quickSuggestions": {
        "other": true,
        "comments": true,
        "strings": true
      },

    "terminal.integrated.fontFamily": "'Fira Mono for Powerline', 'Fira Code', 'Source Code Pro for Powerline', Menlo, Monaco, 'Courier New', monospace",
    "terminal.integrated.fontSize": 16,

    "javascript.implicitProjectConfig.checkJs": true,

    // Requires the todo highlight extension:
    //   code --install-extension wayou.vscode-todo-highlight
    "todohighlight.keywords": [
        "TODO:",
        "FIXME:",
        "HACK:",
        "XXX:",
        "???:",
        "!!!:",
        "PERF:"
    ],

    "search.useIgnoreFilesByDefault": true,
    "search.exclude": {
        "**/node_modules": true,
        "**/bower_components": true,
        "**/dist": true,
        "**/build": true
    },

    "files.insertFinalNewline": true,
    "files.associations": {
        "*.install": "php",
        "*.module": "php",
        "*.inc": "php",
        "*.info": "ini",
        "*.test": "php",
        "*.theme": "php"
    },
    "files.trimFinalNewlines": true,
    "files.trimTrailingWhitespace": true,
    "files.exclude": {
        "**/[._]*.s[a-w][a-z]": true,
        "**/[._]s[a-w][a-z]": true,
        "**/*.un~": true,
        "**/\\.\\#*": true,
        "**/\\#*\\#": true
    },

    "window.restoreWindows": "all",
    "window.restoreFullscreen": true,

    "FSharp.fsacRuntime": "netcore",

    "eslint.packageManager": "yarn",
    "workbench.sideBar.location": "left",
    "editor.tabCompletion": "on"
}
