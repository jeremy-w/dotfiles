# vi: set noet:
[color]
	ui = true
[user]
	name = Jeremy W. Sherman
	email = jeremyw.sherman@gmail.com
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIDBZPP/147Kek3NgN/52OvJZIuh7mvMrX/3nhUMymWVE
# Shared .gitconfig example:
#
#     [includeIf "gitdir:~/path/to/root/dir/**"]
#     	path = "~/path/to/root/dir/.gitconfig"
#
# This makes setting user.email for a group of checkouts really easy!
[includeIf "gitdir:~/BNR/**"]
	path = "~/BNR/.gitconfig"
[includeIf "gitdir:~/BNR/banno/**"]
	path = "~/BNR/banno/.gitconfig"
[pack]
	threads = 0
[diff]
	renamelimit = 0
	compactionHeuristic = true
	algorithm = histogram
	colorMoved = dimmed-zebra
	mnemonicPrefix = true
	renames = true
[diff "swift"]
	xfuncname = ((func|class|protocol|extension)\\s+.*)$
[diff "kotlin"]
	xfuncname = ((fun|class|enum|object)\\s+.*)$
[github]
	user = jeremy-w
	token = 5f45f05510ca7db6d957a60de298ad1b
[core]
	attributesFile = ~/.gitattributes
#	autocrlf = input
  excludesfile = ~/.gitignore
	pager = delta
[delta]
	navigate = true
	line-numbers = true
[interactive]
	diffFilter = delta --color-only
[rebase]
	autosquash = true
	autoStash = true
	updateRefs = true
	missingCommitsCheck = error
	abbreviateCommands = true
[push]
	default = current
	recurseSubmodules = check
	followTags = true
	autoSetupRemote = true
[branch]
	autosetupmerge = true
	sort = -committerdate
[ghi]
	token = 4c1a173d34ce31bfcaadd62433c4a823936e8860
[credential]
	helper = osxkeychain
# Installed by microsoft/scalar.
#	helper = /usr/local/share/gcm-core/git-credential-manager-core
[alias]
	co = checkout
	br = branch
	ci = commit
	st = status
	p = pull --rebase --ff-only
	lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
	lgg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative --name-status
	ll = log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --numstat
	ld = log --pretty=format:"%C(yellow)%h\\ %C(green)%ad%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --date=short --graph
	ls = log --pretty=format:"%C(green)%h\\ %C(yellow)[%ad]%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --date=relative
	quickserve = daemon --verbose --export-all --base-path=.git --reuseaddr --strict-paths .git/
[submodule]
	fetchJobs = 7
	stickyRecursiveClone = true
[merge]
	# (just 'diff3' if git version < 2.3)
	conflictstyle = zdiff3
[rerere]
	enabled = true
	autoUpdate = true
[status]
	submodulesummary = 1
[pull]
	rebase = true
[init]
	defaultBranch = main
[credential "https://dev.azure.com"]
	useHttpPath = true
[help]
	autoCorrect = prompt
[remote "origin"]
	fetch = +refs/notes/*:refs/notes/*
[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
[commit]
	gpgsign = true
	verbose = true
#
# Via: https://blog.gitbutler.com/how-git-core-devs-configure-git/
[column]
	ui = auto
[fetch]
	prune = true
	pruneTags = true
	all = true
