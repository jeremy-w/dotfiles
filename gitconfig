[color]
	ui = true
[user]
	name = Jeremy W. Sherman
	email = jeremyw.sherman@gmail.com
[pack]
	threads = 0
[diff]
	renamelimit = 0
	compactionHeuristic = true
[github]
	user = jeremy-w
	token = 5f45f05510ca7db6d957a60de298ad1b
[core]
#	autocrlf = input
  excludesfile = ~/.gitignore
	pager = /usr/local/share/git-core/contrib/diff-highlight/diff-highlight | less -R
[rebase]
	autosquash = true
	missingCommitsCheck = error
	abbreviateCommands = true
[push]
	default = current
	recurseSubmodules = check
[branch]
	autosetupmerge = true
[ghi]
	token = 4c1a173d34ce31bfcaadd62433c4a823936e8860
[credential]
	helper = osxkeychain
[alias]
	co = checkout
	br = branch
	ci = commit
	st = status
	p = pull --rebase --ff-only
	lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
	lgg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative --name-status
	ll = log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --numstat
	ld = log --pretty=format:"%C(yellow)%h\\ %C(green)%ad%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --date=short --graph
	ls = log --pretty=format:"%C(green)%h\\ %C(yellow)[%ad]%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --date=relative
[submodule]
	fetchJobs = 7
[pager]
	log = /usr/local/share/git-core/contrib/diff-highlight/diff-highlight | less -R
	show = /usr/local/share/git-core/contrib/diff-highlight/diff-highlight | less -R
	diff = /usr/local/share/git-core/contrib/diff-highlight/diff-highlight | less -R
[interactive]
	diffFilter = /usr/local/share/git-core/contrib/diff-highlight/diff-highlight
[merge]
	conflictstyle = diff3
[rerere]
	enabled = true
[status]
	submodulesummary = 1
