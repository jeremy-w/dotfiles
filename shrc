# Configuration file - shared by bash and zsh,
# read by all interactive shells.

export PATH="$HOME/usr/bin:$HOME/.cabal/bin:/usr/local/bin:/usr/local/sbin:$HOME/urbi-root/bin:$PATH:/usr/libexec:/Developer/usr/bin:/Developer/usr/sbin:$HOME/storm-curr/bin:$HOME/.rbenv/versions/1.9.2-p290/bin:/Library/Frameworks/Mono.framework/Commands"
export NODE_PATH="/usr/local/lib/node_modules"
has () {
  which "$1" 2>&1 >/dev/null
}
if has rbenv; then
  eval "$(rbenv init -)"
fi

PERL_CPANM_OPT="--local-lib=~/perl5"

if [ $(uname) = "Darwin" ]; then
  alias ls='ls -FG'
else
  alias ls='ls -F --color'
fi
alias grep='grep --color'
alias mq='hg -R $(hg root)/.hg/patches'
if has hub; then
  eval "$(hub alias -s)"
fi

alias lsregister='/System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister'
alias xmlcat="sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g'"
alias rot13="tr 'A-Za-z' 'N-ZA-Mn-za-m'"

# Load autojump
if has brew; then
  if test -f `brew --prefix`/etc/autojump; then
    source `brew --prefix`/etc/autojump
  fi
fi

# Load nvm
if `test -e "$HOME/.nvm/nvm.sh"`; then
  export NVM_DIR="$HOME/.nvm"
  source "$HOME/.nvm/nvm.sh"
fi

# 10.6.4+ - generate symbols; assumes a kernel debug kit is mounted
# user must supply appropriate -arch and kext
alias ksym="kextutil -c -e -k /Volumes/KernelDebugKit/mach_kernel -n -z -r /Volumes/KernelDebugKit/ -s ."

export SVN_EDITOR="/usr/bin/vim"
export MANPATH="$HOME/.cabal/share/man:/usr/local/share/man:$MANPATH:$HOME/usr/share/man"


## Pretty up less
# -R => interpret ANSI color control sequences
export LESS="-R"

## DocBook SGML Environment
export SGML_CATALOG_FILES="${HOME}/share/sgml/docbook/4.2/catalog:/opt/macports/share/OpenSP/catalog:/opt/macports/share/sgml/iso8879/catalog:/opt/macports/share/sgml/openjade/catalog"
#export SGML_CATALOG_FILES="/opt/macports/openjade/dsssl/catalog:/usr/local/dbtools/dtd3.1/docbook.cat:/usr/local/dbtools/docbook-dsssl/catalog"

export IRTRANS_ROOT="$HOME/Clark/Urbi/irtrans/src/urbi"
export CSZW="$HOME/Clark/ZWave/MJC Framework Mods/deviceplugins/ZWave"
export IOS="/Applications/Xcode.app/Contents/Developer/Platforms/iPhoneOS.platform/Developer/SDKs/iPhoneOS6.0.sdk/"

export LANG="en_US.UTF-8" LC_CTYPE="UTF-8"
export EDITOR="/usr/bin/vim"

export GOPATH="$HOME/usr/share/go"
export PATH="$PATH:$GOPATH/bin"
